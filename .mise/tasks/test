#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Validate build artifacts"
#USAGE flag "-b --bsp <bsp>" help="BSP target to validate" default="x86_64" {
#USAGE   choices "x86_64" "orin-nx" "rk1" "soquartz"
#USAGE }
#USAGE flag "-c --ci" help="CI mode"
# TODO: Implement CI mode behavior (e.g., machine-readable output, stricter validation)
set -o errexit
set -o nounset
set -o pipefail

_bsp="${usage_bsp:-x86_64}"

# shellcheck source=.mise/tasks/_lib.sh
source "${MISE_CONFIG_ROOT}/.mise/tasks/_lib.sh"
_machine=$(bsp_to_machine "${_bsp}")
_deploy_dir="${LAMADIST_HOST_DEPLOY_DIR}/images/${_machine}"

echo "==> Checking build artifact directory: ${_deploy_dir}"
if [ ! -d "${_deploy_dir}" ]; then
	echo "ERROR: Deploy directory does not exist: ${_deploy_dir}"
	exit 1
fi

echo "==> Listing build artifacts:"
ls -lh "${_deploy_dir}/"

# Check for WIC image (prefer uncompressed, then newest compressed)
_wic_image=$(find "${_deploy_dir}" -maxdepth 1 -name "*.wic" ! -name "*.wic.*" | sort | tail -1)
if [ -z "${_wic_image}" ]; then
	_wic_image=$(find "${_deploy_dir}" -maxdepth 1 \( -name "*.wic.zst" -o -name "*.wic.xz" -o -name "*.wic.gz" -o -name "*.wic.bz2" \) | sort | tail -1)
fi
if [ -z "${_wic_image}" ]; then
	echo "ERROR: No WIC image found in ${_deploy_dir}"
	exit 1
fi
echo "==> Found WIC image: ${_wic_image}"
echo "==> Size: $(du -h "${_wic_image}" | cut -f1)"

# Check for kernel image
_kernel_image=$(find "${_deploy_dir}" -maxdepth 1 -name "bzImage*" | head -1)
if [ -z "${_kernel_image}" ]; then
	echo "WARNING: No kernel image (bzImage) found in ${_deploy_dir}"
else
	echo "==> Found kernel image: ${_kernel_image}"
fi

echo "==> Build artifact validation passed"
