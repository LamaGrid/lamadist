#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Build images for specified BSP"
#USAGE flag "-b --bsp <bsp>" help="BSP target to build" default="x86_64" {
#USAGE   choices "x86_64" "orin-nx" "rk1" "soquartz"
#USAGE }
#USAGE flag "-c --ci" help="CI mode: non-interactive, force checkout, no debug config"
set -euo pipefail

BSP="${usage_bsp:-x86_64}"
CI="${usage_ci:-false}"

KAS_CONFIG="${KAS_WORK_DIR}/kas/main.kas.yml:${KAS_WORK_DIR}/kas/bsp/${BSP}.kas.yml"

if [ "${CI}" = "true" ]; then
    # CI mode: run kas directly (already inside builder container)
    mkdir -p "${SSTATE_DIR}"
    kas build --force-checkout --update "${KAS_CONFIG}"
else
    # Local dev: run kas inside container via podman/docker
    KAS_DEBUG="${KAS_WORK_DIR}/kas/extras/debug.kas.yml"
    KAS_CONFIG="${KAS_CONFIG}:${KAS_DEBUG}"

    source "${LAMADIST_PROJECT_DIR}/.mise/tasks/_lib.sh"
    run_in_container build "${KAS_CONFIG}"
fi
