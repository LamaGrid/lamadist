#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Build images for specified BSP"
#USAGE flag "-b --bsp <bsp>" help="BSP target to build" default="x86_64" {
#USAGE   choices "x86_64" "orin-nx" "rk1" "soquartz"
#USAGE }
#USAGE flag "-c --ci" help="CI mode: non-interactive, force checkout"
#USAGE flag "-q --qa" help="QA mode: zstd compression for faster QA/PR builds"
#USAGE flag "-r --release" help="Release mode: machine-default xz compression, CVE checks"
#USAGE flag "-s --include-scans" help="Enable security scans (CVE manifest generation)"
#MISE depends=["gitversion"]
set -euo pipefail

BSP="${usage_bsp:-x86_64}"
CI="${usage_ci:-false}"
QA="${usage_qa:-false}"
RELEASE="${usage_release:-false}"
INCLUDE_SCANS="${usage_include_scans:-false}"

# --release implies --include-scans
if [ "${RELEASE}" = "true" ]; then
	INCLUDE_SCANS="true"
fi

# Source version variables computed by the 'version' dependency task.
GITVERSION_ENV="${LAMADIST_PROJECT_DIR}/.cache/gitversion.env"
if [ -f "${GITVERSION_ENV}" ]; then
	source "${GITVERSION_ENV}"
fi

# Generate dynamic KAS overlay for version and build settings.
# bitbake parses local.conf BEFORE distro.conf and bbclasses, so:
#   - DISTRO_VERSION: use ?= in lamadist.conf, plain = here (local.conf wins)
#   - BUILDSTATS_BASE: upstream class uses =, overrides local.conf;
#     use :lamadist distro override which has higher priority than plain =
DYNAMIC_OVERLAY="${LAMADIST_PROJECT_DIR}/.cache/dynamic.kas.yml"
mkdir -p "$(dirname "${DYNAMIC_OVERLAY}")"
cat > "${DYNAMIC_OVERLAY}" <<- OVERLAY
	# Auto-generated by the build task — do not edit
	header:
	  version: 15
	local_conf_header:
	  dynamic_build_settings: |
	    BUILDSTATS_BASE:lamadist = '${BUILDSTATS_BASE}'
OVERLAY
if [ -n "${BUILDNAME:-}" ]; then
	cat >> "${DYNAMIC_OVERLAY}" <<- OVERLAY
	    BUILDNAME = '${BUILDNAME}'
	OVERLAY
fi
if [ -n "${DISTRO_VERSION:-}" ]; then
	cat >> "${DYNAMIC_OVERLAY}" <<- OVERLAY
	    DISTRO_VERSION = '${DISTRO_VERSION}'
	OVERLAY
fi
# Note: DISTRO_VERSION[vardepvalue] is intentionally NOT set here.
# lamadist.conf sets it to the constant DISTRO_VERSION_BASE via ?=,
# which keeps sstate hashes stable across commits.

KAS_CONFIG="${KAS_WORK_DIR}/kas/main.kas.yml:${KAS_WORK_DIR}/kas/bsp/${BSP}.kas.yml:${KAS_WORK_DIR}/.cache/dynamic.kas.yml"

# Append build-stage overlays:
#   --qa:      zstd compression (QA/PR builds)
#   --release: no overlay — machine defaults (xz -9e) take effect
#   neither:   debug overlay (local dev, no compression)
if [ "${QA}" = "true" ] && [ "${RELEASE}" != "true" ]; then
	KAS_CONFIG="${KAS_CONFIG}:${KAS_WORK_DIR}/kas/extras/qa.kas.yml"
elif [ "${CI}" != "true" ]; then
	KAS_CONFIG="${KAS_CONFIG}:${KAS_WORK_DIR}/kas/extras/debug.kas.yml"
fi

# Scans overlay (CVE manifest generation)
if [ "${INCLUDE_SCANS}" = "true" ]; then
	KAS_CONFIG="${KAS_CONFIG}:${KAS_WORK_DIR}/kas/extras/scans.kas.yml"
fi

# Record scan marker for pre-push hook
if [ "${INCLUDE_SCANS}" = "true" ]; then
	mkdir -p "${LAMADIST_PROJECT_DIR}/.cache"
	git -C "${LAMADIST_PROJECT_DIR}" rev-parse HEAD > "${LAMADIST_PROJECT_DIR}/.cache/last-scan-sha" 2>/dev/null || true
fi

if [ "${CI}" = "true" ]; then
	# CI mode: run kas directly (already inside builder container)
	mkdir -p "${SSTATE_DIR}"
	kas build --force-checkout --update "${KAS_CONFIG}"
else
	# Local dev: run kas inside container via podman/docker
	source "${LAMADIST_PROJECT_DIR}/.mise/tasks/_lib.sh"
	run_in_container build "${KAS_CONFIG}"
fi
