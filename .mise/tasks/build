#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Build images for specified BSP"
#USAGE flag "-b --bsp <bsp>" help="BSP target to build" default="x86_64" {
#USAGE   choices "x86_64" "orin-nx" "rk1" "soquartz"
#USAGE }
#USAGE flag "-c --ci" help="CI mode: non-interactive, force checkout"
#USAGE flag "-q --qa" help="QA mode: zstd compression for faster QA/PR builds"
#USAGE flag "-r --release" help="Release mode: machine-default xz compression, CVE checks"
#USAGE flag "-s --include-scans" help="Enable security scans (CVE manifest generation)"
#MISE depends=["info"]
set -o errexit
set -o nounset
set -o pipefail

_bsp="${usage_bsp:-x86_64}"
_ci="${usage_ci:-false}"
_qa="${usage_qa:-false}"
_release="${usage_release:-false}"
_include_scans="${usage_include_scans:-false}"

# --release implies --include-scans
if [ "${_release}" = "true" ]; then
	_include_scans="true"
fi

# Source version variables computed by the 'version' dependency task.
_gitversion_env="${MISE_CONFIG_ROOT}/.cache/gitversion.env"
if [ -f "${_gitversion_env}" ]; then
	# shellcheck source=/dev/null
	source "${_gitversion_env}"
fi

# Generate dynamic KAS overlay for version and build settings.
# bitbake parses local.conf BEFORE distro.conf and bbclasses, so:
#   - DISTRO_VERSION: use ?= in lamadist.conf, plain = here (local.conf wins)
#   - BUILDSTATS_BASE: upstream class uses =, overrides local.conf;
#     use :lamadist distro override which has higher priority than plain =
_dynamic_overlay="${MISE_CONFIG_ROOT}/.cache/dynamic.kas.yml"
mkdir -p "$(dirname "${_dynamic_overlay}")"
cat > "${_dynamic_overlay}" <<- OVERLAY
	# Auto-generated by the build task — do not edit
	header:
	  version: 15
	local_conf_header:
	  05_dynamic: |
	    BUILDSTATS_BASE:lamadist = '${BUILDSTATS_BASE}'
OVERLAY
if [ -n "${BUILDNAME:-}" ]; then
	cat >> "${_dynamic_overlay}" <<- OVERLAY
	    BUILDNAME = '${BUILDNAME}'
	OVERLAY
fi
if [ -n "${DISTRO_VERSION:-}" ]; then
	cat >> "${_dynamic_overlay}" <<- OVERLAY
	    DISTRO_VERSION = '${DISTRO_VERSION}'
	OVERLAY
fi
# Note: DISTRO_VERSION[vardepvalue] is intentionally NOT set here.
# lamadist.conf sets it to the constant DISTRO_VERSION_BASE via ?=,
# which keeps sstate hashes stable across commits.

_kas_config="${KAS_WORK_DIR}/kas/main.kas.yml:${KAS_WORK_DIR}/kas/bsp/${_bsp}.kas.yml:${KAS_WORK_DIR}/.cache/dynamic.kas.yml:${KAS_WORK_DIR}/kas/extras/sbom.kas.yml"

# Append build-stage overlays:
#   --qa:      zstd compression (QA/PR builds)
#   --release: no overlay — machine defaults (xz -9e) take effect
#   neither:   debug overlay (local dev, no compression)
if [ "${_qa}" = "true" ] && [ "${_release}" != "true" ]; then
	_kas_config="${_kas_config}:${KAS_WORK_DIR}/kas/extras/qa.kas.yml"
elif [ "${_ci}" != "true" ]; then
	_kas_config="${_kas_config}:${KAS_WORK_DIR}/kas/extras/debug.kas.yml"
fi

# CVE manifest overlay
if [ "${_include_scans}" = "true" ]; then
	_kas_config="${_kas_config}:${KAS_WORK_DIR}/kas/extras/cve.kas.yml"
fi

# Record scan marker for pre-push hook
if [ "${_include_scans}" = "true" ]; then
	mkdir -p "${MISE_CONFIG_ROOT}/.cache"
	git -C "${MISE_CONFIG_ROOT}" rev-parse HEAD > "${MISE_CONFIG_ROOT}/.cache/last-scan-sha" 2>/dev/null || true
fi

if [ "${_ci}" = "true" ]; then
	# CI mode: run kas directly (already inside builder container)
	mkdir -p "${SSTATE_DIR}"
	kas build --force-checkout --update "${_kas_config}"
else
	# Local dev: run kas inside container via podman/docker

	# Check dependency lockfile freshness
	if ! output=$(mise run container:builder:verify 2>&1); then
		status=$?
		echo "${output}"
		if [ "${status}" -eq 2 ]; then
			exit 1
		fi
	fi

	# shellcheck source=.mise/tasks/_lib.sh
	source "${MISE_CONFIG_ROOT}/.mise/tasks/_lib.sh"
	run_in_container build "${_kas_config}"
fi
