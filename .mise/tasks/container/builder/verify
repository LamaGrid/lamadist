#!/usr/bin/env bash
#MISE description="Check if container dependency updates are available (APT, Python)"
#MISE depends=["container:builder:lock:python"]

set -o errexit
set -o nounset
set -o pipefail

_container_cmd="${LAMADIST_CONTAINER_CMD:-podman}"
if ! command -v "$_container_cmd" &> /dev/null; then
	if command -v docker &> /dev/null; then
		_container_cmd="docker"
	else
		echo "Error: Neither podman nor docker found." >&2
		exit 1
	fi
fi

# 0. Check lockfile age
_lock_file="${MISE_CONFIG_ROOT}/container/packages.lock"
if [ ! -f "$_lock_file" ]; then
	echo "Error: $_lock_file not found." >&2
	exit 2
fi

file_age=$(($(date +%s) - $(date -r "$_lock_file" +%s)))
days_old=$((file_age / 86400))

if [ "$days_old" -gt 7 ]; then
	echo "Error: $_lock_file is stale (>7 days old). Run 'mise run container:builder:lock'." >&2
	exit 2
fi

# Check if the builder image exists
_container_image='localhost/lamagrid/lamadist-builder:latest'
if ! "$_container_cmd" image inspect "$_container_image" > /dev/null 2>&1; then
	echo "Error: Container image $_container_image not found. Build it first with 'mise run container:builder:build'." >&2
	exit 3
fi

# Start the container and check for python and apt updates
"$_container_cmd" run --rm \
	--volume "${MISE_CONFIG_ROOT}/container:/mnt:ro" \
	--workdir /mnt \
	--user root \
	--entrypoint '["/bin/dumb-init", "/bin/bash", "-c"]' \
	$_container_image \
	/mnt/check_updates.sh
