#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Remove saved buildstats snapshots"
#USAGE flag "-k --keep <n>" help="Keep the N most recent snapshots (default: remove all)"
set -o errexit
set -o nounset
set -o pipefail

_buildstats_base_dir="${LAMADIST_HOST_BUILDSTATS_BASE}"

if [ ! -d "${_buildstats_base_dir}" ]; then
	echo "No saved buildstats snapshots to clean."
	exit 0
fi

snapshots=()
while IFS= read -r dir; do
	snapshots+=("${dir}")
done < <(find "${_buildstats_base_dir}" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' \
	| sort -n | cut -d' ' -f2-)

if [ ${#snapshots[@]} -eq 0 ]; then
	echo "No saved buildstats snapshots to clean."
	exit 0
fi

_keep="${usage_keep:-0}"

if [ "${_keep}" -ge "${#snapshots[@]}" ]; then
	echo "Nothing to remove (${#snapshots[@]} snapshots, keeping ${_keep})."
	exit 0
fi

if [ "${_keep}" -gt 0 ]; then
	_remove_count=$(( ${#snapshots[@]} - _keep ))
	to_remove=("${snapshots[@]:0:${_remove_count}}")
else
	to_remove=("${snapshots[@]}")
fi

echo "Snapshots to remove:"
for dir in "${to_remove[@]}"; do
	echo "  $(basename "${dir}")"
done

if [ -t 0 ]; then
	read -p "Remove ${#to_remove[@]} snapshot(s)? [y/N] " -n 1 -r
	echo
	if [[ ! $REPLY =~ ^[Yy]$ ]]; then
		echo "Aborted."
		exit 1
	fi
fi

for dir in "${to_remove[@]}"; do
	rm -rf "${dir}"
done

echo "Removed ${#to_remove[@]} snapshot(s)."
