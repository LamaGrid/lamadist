#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Remove entire build and deploy directories (with confirmation)"
set -euo pipefail
if [ -t 0 ]; then
    read -p "Remove all build and deploy contents? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 1
    fi
fi
rm -rf "${LAMADIST_HOST_BUILD_DIR:?}"/* "${LAMADIST_HOST_BUILD_DIR}"/.??* 2>/dev/null || true
rm -rf "${LAMADIST_HOST_DEPLOY_DIR:?}"/* "${LAMADIST_HOST_DEPLOY_DIR}"/.??* 2>/dev/null || true
echo "Cleaned build and deploy directories."
