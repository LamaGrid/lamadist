#!/usr/bin/env bash
#MISE description="Check if dependency updates are available (APT, Python, Mise)"

set -uo pipefail

CONTAINER_CMD="${LAMADIST_CONTAINER_CMD:-podman}"
if ! command -v "$CONTAINER_CMD" &> /dev/null; then
	if command -v docker &> /dev/null; then
		CONTAINER_CMD="docker"
	else
		echo "Error: Neither podman nor docker found." >&2
		exit 1
	fi
fi

# 0. Check lockfile age
LOCK_FILE="container/packages.lock"
if [ ! -f "$LOCK_FILE" ]; then
	echo "Error: $LOCK_FILE not found." >&2
	exit 2
fi

file_age=$(($(date +%s) - $(date -r "$LOCK_FILE" +%s)))
days_old=$((file_age / 86400))

if [ "$days_old" -gt 7 ]; then
	echo "Error: $LOCK_FILE is stale (>7 days old). Run 'mise run container:update'." >&2
	exit 2
fi

# 1. Check APT updates
echo "Checking APT updates..."
# Use dry-run logic
"$CONTAINER_CMD" run --rm \
	--volume "$(pwd)/container:/mnt" \
	--workdir /mnt \
	ubuntu:22.04 \
	bash -c "apt-get update >/dev/null &&
	while read -r line; do
		[[ \"\$line\" =~ ^#.*$ ]] && continue
		[[ -z \"\$line\" ]] && continue
		pkg=\"\${line%%=*}\"
		current_version=\"\${line##*=}\"
		candidate_version=\$(apt-cache policy \"\$pkg\" | grep 'Candidate:' | awk '{print \$2}')
		if [ \"\$candidate_version\" != \"\$current_version\" ]; then
			echo \"Update available for \$pkg: \$current_version -> \$candidate_version\"
			exit 1
		fi
	done < packages.lock" || {
		echo "APT updates available!"
		exit 1
	}

# 2. Check Python updates
echo "Checking Python updates..."
# dry-run with upgrade to see if output changes?
# uv pip compile --upgrade --dry-run doesn't exist.
# We can check if `uv pip compile --upgrade` WOULD produce a diff.

"$CONTAINER_CMD" run --rm \
	--volume "$(pwd)/container:/mnt" \
	--workdir /mnt \
	docker.io/python:3.10-slim \
	bash -c "pip install --no-cache-dir uv >/dev/null 2>&1 && \
			 uv pip compile --no-header --upgrade pyproject.toml -o - 2>/dev/null | diff -q requirements.txt -" >/dev/null || {
		echo "Python updates available!"
		exit 1
	}

# 3. Check Mise updates
echo "Checking Mise updates..."
# mise outdated returns exit code 0 if outdated? No, 0 if success.
# mise outdated --json | jq ...
# If `mise outdated` has output, updates are available?
if [ "$(mise outdated --json | jq '. | length')" -gt 0 ]; then
	echo "Mise updates available!"
	mise outdated
	exit 1
fi

echo "All dependencies up to date."
exit 0
