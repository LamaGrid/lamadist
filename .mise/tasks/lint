#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Validate KAS configuration"
#USAGE flag "-b --bsp <bsp>" help="BSP target to validate" default="x86_64" {
#USAGE   choices "x86_64" "orin-nx" "rk1" "soquartz"
#USAGE }
#USAGE flag "-c --ci" help="CI mode: non-interactive"
set -euo pipefail

BSP="${usage_bsp:-x86_64}"
CI="${usage_ci:-false}"

KAS_CONFIG="${KAS_WORK_DIR}/kas/main.kas.yml:${KAS_WORK_DIR}/kas/bsp/${BSP}.kas.yml"

echo "==> Validating KAS configuration for BSP: ${BSP}"

if [ "${CI}" = "true" ]; then
	# CI mode: run kas directly (already inside builder container)
	mkdir -p "${SSTATE_DIR}"
	kas dump "${KAS_CONFIG}"
else
	# Local dev: run kas inside container via podman/docker
	source "${LAMADIST_PROJECT_DIR}/.mise/tasks/_lib.sh"
	run_in_container dump "${KAS_CONFIG}"
fi

echo "==> KAS configuration validation passed"
