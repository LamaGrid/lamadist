#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Compare buildstats between two saved snapshots"
#USAGE arg "<from>" help="Baseline snapshot label" required
#USAGE arg "<to>" help="Comparison snapshot label" required
#USAGE complete "from" run="mise run stats:_labels"
#USAGE complete "to" run="mise run stats:_labels"
#USAGE flag "-a --attr <attr>" help="Attribute to compare" default="walltime" {
#USAGE   choices "walltime" "cputime" "read_bytes" "write_bytes" "read_ops" "write_ops"
#USAGE }
set -o errexit
set -o nounset
set -o pipefail

_buildstats_base_dir="${LAMADIST_HOST_BUILDSTATS_BASE}"
_script="${MISE_CONFIG_ROOT}/ext/poky/scripts/buildstats-diff"

if [ ! -x "${_script}" ]; then
	echo "ERROR: buildstats-diff script not found at ${_script}"
	exit 1
fi

_from_path="${_buildstats_base_dir}/${usage_from:-}"
_to_path="${_buildstats_base_dir}/${usage_to:-}"

if [ ! -d "${_from_path}" ]; then
	echo "ERROR: Snapshot '${usage_from}' not found"
	echo "Run 'mise run stats:list' to see available snapshots."
	exit 1
fi

if [ ! -d "${_to_path}" ]; then
	echo "ERROR: Snapshot '${usage_to}' not found"
	echo "Run 'mise run stats:list' to see available snapshots."
	exit 1
fi

echo "==> Comparing buildstats: ${usage_from} → ${usage_to}"
echo "    Attribute: ${usage_attr:-walltime}"
echo ""

"${_script}" \
	--diff-attr "${usage_attr:-walltime}" \
	"${_from_path}" "${_to_path}"
